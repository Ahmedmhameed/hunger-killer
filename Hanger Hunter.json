              "body": "{\n  \"success\": true,\n  \"message\": \"Addresses retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": \"660e8400-e29b-41d4-a716-446655440001\",\n      \"label\": \"Home\",\n      \"street\": \"Al-Rimal Street, Building 12, Apartment 3\",\n      \"city\": \"Gaza\",\n      \"gpsLat\": 31.5017,\n      \"gpsLng\": 34.4667,\n      \"createdAt\": \"2026-05-30T10:15:00\",\n      \"updatedAt\": \"2026-05-30T10:15:00\"\n    }\n  ],\n  \"timestamp\": \"2026-05-30T10:20:00\"\n}"
            }
          ]
